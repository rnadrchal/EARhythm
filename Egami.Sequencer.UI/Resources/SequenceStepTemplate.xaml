<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:seq="clr-namespace:Egami.Sequencer;assembly=Egami.Sequencer"
                    xmlns:converters="clr-namespace:Egami.Sequencer.UI.Converters">

    <converters:ValueToPixelsConverter x:Key="ValToPx" />
    <converters:ValueAndContainerToWidthConverter x:Key="ValueAndContainerToWidth" />
    <converters:NoteNumberConverter x:Key="NoteNumber" />
    <converters:AddConverter x:Key="Add" />

    <!-- Implizites DataTemplate für SequenceStep: transparentes Rechteck + roter Pitch-Balken -->
    <DataTemplate DataType="{x:Type seq:SequenceStep}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{Binding StepIndex, ConverterParameter=1, Converter={StaticResource Add}}"
                       TextAlignment="Center"/>

            <Border x:Name="StepBorder"
                    Grid.Row="1"
                Padding="0"
                Background="Transparent"
                BorderBrush="#FFF"
                BorderThickness="1"
                Width="{Binding LengthInSteps, Converter={StaticResource ValToPx}, ConverterParameter=24}">
                <Grid Height="40" ClipToBounds="True">
                    <!-- Hintergrund (transparent) -->

                    <!-- Pitch-Histogramm als VERTIKALER Balken (grow up from bottom) -->
                    <Rectangle Fill="#800"
                           VerticalAlignment="Bottom"
                           RadiusX="2" RadiusY="2">
                        <Rectangle.Height>
                            <MultiBinding Converter="{StaticResource ValueAndContainerToWidth}" ConverterParameter="127">
                                <Binding Path="Pitch" />
                                <!-- Wichtig: hier ActualHeight statt ActualWidth -->
                                <Binding ElementName="StepBorder" Path="ActualHeight" />
                            </MultiBinding>
                        </Rectangle.Height>
                        <Rectangle.ToolTip>
                            <TextBlock>
                            <Run Text="Pitch:" />
                            <Run Text="{Binding Pitch, Converter={StaticResource NoteNumber}, Mode=OneWay}"></Run>
                            </TextBlock>
                        </Rectangle.ToolTip>
                    </Rectangle>


                    <!-- Vertikale Anzeige der Zahl (gedreht) -->
                    <!--<TextBlock Text="{Binding Pitch}"
                           FontSize="10"
                           Foreground="Black"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Bottom"
                           Margin="0,0,0,2">
                    <TextBlock.RenderTransform>
                        <RotateTransform Angle="-90" />
                    </TextBlock.RenderTransform>
                </TextBlock>-->
                </Grid>
            </Border>

            <Border x:Name="VelocityBorder"
                    Grid.Row="2"
                Padding="0"
                Background="Transparent"
                BorderBrush="#FFF"
                BorderThickness="1"
                Width="{Binding LengthInSteps, Converter={StaticResource ValToPx}, ConverterParameter=24}">
                <Grid Height="40" ClipToBounds="True">
                    <!-- Hintergrund (transparent) -->

                    <!-- Pitch-Histogramm als VERTIKALER Balken (grow up from bottom) -->
                    <Rectangle Fill="#448"
                           VerticalAlignment="Bottom"
                           RadiusX="2" RadiusY="2">
                        <Rectangle.Height>
                            <MultiBinding Converter="{StaticResource ValueAndContainerToWidth}" ConverterParameter="127">
                                <Binding Path="Velocity" />
                                <!-- Wichtig: hier ActualHeight statt ActualWidth -->
                                <Binding ElementName="StepBorder" Path="ActualHeight" />
                            </MultiBinding>
                        </Rectangle.Height>
                        <Rectangle.ToolTip>
                            <TextBlock>
                            <Run Text="Velocity:" />
                            <Run Text="{Binding Velocity, Mode=OneWay}" />
                            </TextBlock>
                        </Rectangle.ToolTip>
                    </Rectangle>

                </Grid>
            </Border>
            <Border x:Name="PitchbendBorder"
                    Grid.Row="3"
                    Padding="0"
                    Background="Transparent"
                    BorderBrush="#FFF"
                    BorderThickness="1"
                    Width="{Binding LengthInSteps, Converter={StaticResource ValToPx}, ConverterParameter=24}">
                <Grid Height="40" ClipToBounds="True">
                    <!-- Hintergrund (transparent) -->

                    <!-- Pitch-Histogramm als VERTIKALER Balken (grow up from bottom) -->
                    <Rectangle Fill="#888"
                               VerticalAlignment="Bottom"
                               RadiusX="2" RadiusY="2">
                        <Rectangle.Height>
                            <MultiBinding Converter="{StaticResource ValueAndContainerToWidth}" ConverterParameter="16384">
                                <Binding Path="PitchBend" />
                                <!-- Wichtig: hier ActualHeight statt ActualWidth -->
                                <Binding ElementName="StepBorder" Path="ActualHeight" />
                            </MultiBinding>
                        </Rectangle.Height>
                        <Rectangle.ToolTip>
                            <TextBlock>
                                <Run Text="Pitch bend:" />
                                <Run Text="{Binding Pitch, Mode=OneWay}" />
                            </TextBlock>
                        </Rectangle.ToolTip>
                    </Rectangle>

                </Grid>
            </Border>

        </Grid>
    </DataTemplate>
</ResourceDictionary>