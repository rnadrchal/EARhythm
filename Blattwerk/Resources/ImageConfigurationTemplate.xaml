<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Blattwerk.ViewModels"
                    xmlns:converters="clr-namespace:Egami.Sequencer.UI.Converters;assembly=Egami.Sequencer.UI"
                    xmlns:views="clr-namespace:Blattwerk.Views"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
                    xmlns:wpf="clr-namespace:Material.Icons.WPF;assembly=Material.Icons.WPF">
    <converters:EqualityToBrushConverter x:Key="EqualityToBrush" />
    <converters:NotNullToVisibilityConverter x:Key="NotNullToVisibility" />
    <converters:ValuesToPointsConverter x:Key="ValuesToPoints" />
    <converters:EnumDisplayNameConverter x:Key="DisplayName" />

    <Style TargetType="ContentControl" x:Key="ChartStyle">
        <Setter Property="Height" Value="60" />
    </Style>

    <Style TargetType="TextBlock" x:Key="ChartLabelStyle">
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="HorizontalAlignment" Value="Right" />
        <Setter Property="Margin" Value="0,0,5,0" />
    </Style>

    <DataTemplate x:Key="ChartTemplate">
        <Border BorderBrush="#333" BorderThickness="1">
            <Grid x:Name="ChartHost">
                <Canvas>
                    <Polyline Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ContentControl}, FallbackValue=DodgerBlue}"
                              StrokeThickness="1" StrokeLineJoin="Round" Fill="Transparent">
                        <Polyline.Points>
                            <MultiBinding Converter="{StaticResource ValuesToPoints}">
                                <!-- erstes Binding bindet auf das gesamte DataContext/Content (float[]) -->
                                <Binding Path="."/>
                                <!-- Canvas / Host Breite & Höhe -->
                                <Binding ElementName="ChartHost" Path="ActualWidth"/>
                                <Binding ElementName="ChartHost" Path="ActualHeight"/>
                            </MultiBinding>
                        </Polyline.Points>
                    </Polyline>
                </Canvas>
            </Grid>

        </Border>
    </DataTemplate>

    <DataTemplate DataType="{x:Type vm:ImageConfiguration}">
        <ScrollViewer Visibility="{Binding Bitmap, Converter={StaticResource NotNullToVisibility}}"
                      VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>

                <Border Grid.Row="1" Grid.Column="1"
                        Background="#400"
                        Padding="5"
                        Margin="0,0,0,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" 
                                   Style="{StaticResource DigitalTextStyle}"
                                   HorizontalAlignment="Left">
                            <Run Text="{Binding Direction, Mode=OneWay}" />
                            <Run Text="{Binding ColumnOrRow, Mode=OneWay}" />
                        </TextBlock>
                        <TextBlock Grid.Column="1" 
                                   Style="{StaticResource DigitalTextStyle}">
                            <Run Text="Div"></Run>
                            <Run Text="{Binding Divider, Mode=OneWay, Converter={StaticResource DisplayName}}" />
                        </TextBlock>
                        <TextBlock Grid.Column="2" 
                                   Style="{StaticResource DigitalTextStyle}"
                                   HorizontalAlignment="Right">
                            <Run Text="{Binding SegmentCount, Mode=OneWay}" />
                            <Run Text="Steps" />
                        </TextBlock>
                    </Grid>

                </Border>

                <StackPanel Orientation="Vertical" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0"
                            VerticalAlignment="Bottom"
                            Margin="0,0,2,16">
                    <Button Style="{StaticResource Round3DButton}"
                            Width="24" Height="24"
                            Background="{Binding Direction, Converter={StaticResource EqualityToBrush}, ConverterParameter=TopDown}"
                            Command="{Binding SetDirectionCommand}" 
                            CommandParameter="{x:Static vm:ImageDirection.TopDown}"  
                            ToolTip="Top down">
                        <TextBlock Text="↧" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource Round3DButton}"
                            Margin="0,5,0,0"
                            Width="24" Height="24"
                            Background="{Binding Direction, Converter={StaticResource EqualityToBrush}, ConverterParameter=BottomUp}"
                            Command="{Binding SetDirectionCommand}" 
                            CommandParameter="{x:Static vm:ImageDirection.BottomUp}"  
                            ToolTip="Bottom up">
                        <TextBlock Text="↥" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                            Margin="2,0,0,2">
                    <Button Style="{StaticResource Round3DButton}"
                            Width="24" Height="24"
                            Background="{Binding Direction, Converter={StaticResource EqualityToBrush}, ConverterParameter=Ltr}"
                            ToolTip="LTR"
                            Command="{Binding SetDirectionCommand}" 
                            CommandParameter="{x:Static vm:ImageDirection.Ltr}">

                        <TextBlock Text="↦" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                    <Button Style="{StaticResource Round3DButton}"
                            Margin="5,0,0,0"
                            Width="24" Height="24"
                            Background="{Binding Direction, Converter={StaticResource EqualityToBrush}, ConverterParameter=Rtl}"
                            ToolTip="RTL"
                            Command="{Binding SetDirectionCommand}" 
                            CommandParameter="{x:Static vm:ImageDirection.Rtl}">
                        <TextBlock Text="↤" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </StackPanel>

                <syncfusion:SfRadialSlider Grid.Row="0" Width="40" Height="40"
                                           Grid.Column="1" Margin="0,0,170,2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                           Minimum="0" Maximum="11"
                                           Value="{Binding DividerIndex, Mode=TwoWay}"
                                           OuterRimRadiusFactor="0.9"
                                           OuterRimStroke="#444"
                                           OuterRimStrokeThickness="3"
                                           InnerRimFill="#444"
                                           InnerRimStroke="#444"
                                           InnerRimRadiusFactor="0.7"
                                           StartAngle="135" EndAngle="405"
                                           TickFrequency="1"
                                           TickVisibility="Visible"
                                           TickRadiusFactor="0.9" PointerRadiusFactor="0.8" 
                                           LabelVisibility="Collapsed">
                </syncfusion:SfRadialSlider>

                
                <syncfusion:SfRadialSlider Width="40" Height="40"
                                           Grid.Row="0" Grid.Column="1" Margin="0,0,14,2" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                                           Minimum="0" Maximum="4"
                                           Value="{Binding SegmentCountIndex, Mode=TwoWay}"
                                           OuterRimRadiusFactor="0.9"
                                           OuterRimStroke="#444"
                                           OuterRimStrokeThickness="3"
                                           InnerRimFill="#444"
                                           InnerRimStroke="#444"
                                           InnerRimRadiusFactor="0.7"
                                           StartAngle="135" EndAngle="405"
                                           TickFrequency="1"
                                           TickVisibility="Visible"
                                           TickRadiusFactor="0.9" PointerRadiusFactor="0.8" 
                                           LabelVisibility="Collapsed">
                    <wpf:MaterialIcon Kind="Walk" Opacity="0.5" />
                </syncfusion:SfRadialSlider>


                <Border Grid.Row="2" Grid.Column="1"
                        BorderBrush="#666" BorderThickness="0">
                    <Grid Grid.Row="1" Grid.Column="1">
                        <!-- Referenzbild: explizit Stretch + Top alignment -->
                        <Image x:Name="Image"
                               Source="{Binding Bitmap}"
                               Width="384"
                               Stretch="Uniform"
                               VerticalAlignment="Top" />

                        <!-- Overlay bindet seine Height an das Image, Alignment identisch -->
                        <views:ImageOverlayView Source="{Binding Bitmap}"
                                                Direction="{Binding Direction}"
                                                ColumnOrRow="{Binding ColumnOrRow, Mode=TwoWay}"
                                                SegmentCount="{Binding SegmentCount}"
                                                Width="384"
                                                Height="{Binding ActualHeight, ElementName=Image}"
                                                VerticalAlignment="Top"
                                                Opacity="1"/>
                    </Grid>
                </Border>

                <Grid Grid.Row="0" Grid.RowSpan="4" Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30" />
                        <ColumnDefinition Width="256" />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="R"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Red" />
                    <ContentControl Grid.Column="1" Grid.Row="0"
                                    Content="{Binding R}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Red"
                                    Style="{StaticResource ChartStyle}" />
                    <ContentControl Grid.Column="2" Grid.Row="0"
                                    Content="{Binding RConfiguration}" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="G"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Green" />
                    <ContentControl Grid.Column="1" Grid.Row="1"
                                    Content="{Binding G}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Green"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="1"
                                    Content="{Binding GConfiguration}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="B"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Blue" />
                    <ContentControl Grid.Column="1" Grid.Row="2"
                                    Content="{Binding B}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Blue"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="2"
                                    Content="{Binding BConfiguration}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Y"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Yellow" />
                    <ContentControl Grid.Column="1" Grid.Row="3"
                                    Content="{Binding Y}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Yellow"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="3"
                                    Content="{Binding YConfiguration}" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="M"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Magenta" />
                    <ContentControl Grid.Column="1" Grid.Row="4"
                                    Content="{Binding M}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Magenta"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="4"
                                    Content="{Binding MConfiguration}" />
                    <TextBlock Grid.Row="5" Grid.Column="0" Text="C"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Cyan" />
                    <ContentControl Grid.Column="1" Grid.Row="5"
                                    Content="{Binding C}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Cyan"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="5"
                                    Content="{Binding CConfiguration}" />
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="A"
                               Style="{StaticResource ChartLabelStyle}"
                               Foreground="Gray"/>
                    <ContentControl Grid.Column="1" Grid.Row="6"
                                    Content="{Binding A}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="Gray"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="6"
                                    Content="{Binding AConfiguration}" />

                    <Image Grid.Row="7" Grid.Column="0" Source="/Resources/Images/Brightness.png" Width="16"  />
                    <ContentControl Grid.Column="1" Grid.Row="7"
                                    Content="{Binding RecipWeightedBrightness}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="White"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="7"
                                    Content="{Binding BrightnessConfiguration}" />
                    <Image Grid.Row="8" Grid.Column="0" Source="/Resources/Images/Luminance.png" Width="16"  />
                    <ContentControl Grid.Column="1" Grid.Row="8"
                                    Content="{Binding Luminance}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="White"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="8"
                                    Content="{Binding LuminanceConfiguration}" />
                    <Image Grid.Row="9" Grid.Column="0" Source="/Resources/Images/Saturation.png" Width="16" />
                    <ContentControl Grid.Column="1" Grid.Row="9"
                                    Content="{Binding Saturation}"
                                    ContentTemplate="{StaticResource ChartTemplate}"
                                    Foreground="White"
                                    Style="{StaticResource ChartStyle}"/>
                    <ContentControl Grid.Column="2" Grid.Row="9"
                                    Content="{Binding SaturationConfiguration}" />
                </Grid>
            </Grid>
        </ScrollViewer>
    </DataTemplate>
</ResourceDictionary>