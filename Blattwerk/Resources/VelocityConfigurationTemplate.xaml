<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:Blattwerk.ViewModels"
                    xmlns:syncfusion="http://schemas.syncfusion.com/wpf">
    <DataTemplate DataType="{x:Type vm:VelocityConfiguration}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Background="#400" Padding="2">
                <TextBlock Style="{StaticResource DigitalTextStyle}">
                    <Run Text="LO" />
                    <Run Text="{Binding MinValue, Mode=OneWay}" />
                </TextBlock>
            </Border>
            <syncfusion:SfRadialSlider Grid.Column="0" Grid.Row="1" Width="40" Height="40"
                                       Minimum="0" Maximum="127" HorizontalAlignment="Center"
                                       Margin="5,0,5,0"
                                       Value="{Binding MinValue, Mode=TwoWay}"
                                       OuterRimRadiusFactor="0.9"
                                       OuterRimStroke="#444"
                                       OuterRimStrokeThickness="3"
                                       InnerRimFill="#444"
                                       InnerRimStroke="#444"
                                       InnerRimRadiusFactor="0.7"
                                       StartAngle="135" EndAngle="405"
                                       TickFrequency="16"
                                       TickVisibility="Visible"
                                       TickRadiusFactor="0.9" PointerRadiusFactor="0.8" 
                                       LabelVisibility="Collapsed">
            </syncfusion:SfRadialSlider>
            <Border Grid.Row="0" Grid.Column="1" Background="#400" Padding="2">
                <TextBlock Style="{StaticResource DigitalTextStyle}">
                    <Run Text="HI" />
                    <Run Text="{Binding MaxValue, Mode=OneWay}" />
                </TextBlock>
            </Border>
            <syncfusion:SfRadialSlider Grid.Column="1" Grid.Row="1" Width="40" Height="40"
                                       Minimum="0" Maximum="127" HorizontalAlignment="Center"
                                       Margin="5,0,5,0"
                                       Value="{Binding MaxValue, Mode=TwoWay}"
                                       OuterRimRadiusFactor="0.9"
                                       OuterRimStroke="#444"
                                       OuterRimStrokeThickness="3"
                                       InnerRimFill="#444"
                                       InnerRimStroke="#444"
                                       InnerRimRadiusFactor="0.7"
                                       StartAngle="135" EndAngle="405"
                                       TickFrequency="16"
                                       TickVisibility="Visible"
                                       TickRadiusFactor="0.9" PointerRadiusFactor="0.8" 
                                       LabelVisibility="Collapsed">
            </syncfusion:SfRadialSlider>
        </Grid>
    </DataTemplate>
</ResourceDictionary>