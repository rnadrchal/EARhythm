<prism:PrismApplication x:Class="Blattwerk.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/" >
    <Application.Resources>
        <ResourceDictionary>
            <FontFamily x:Key="LED_Real">
                Resources/Fonts/#LED Real
            </FontFamily>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/Egami.Sequencer.UI;component/Resources/Styles.xaml" />
                <ResourceDictionary Source="Resources/Styles.xaml" />
                <ResourceDictionary Source="Resources/PitchConfigurationTemplates.xaml" />
                <ResourceDictionary Source="Resources/VelocityConfigurationTemplate.xaml" />
                <ResourceDictionary Source="Resources/PitchbendConfigurationTemplate.xaml" />
                <ResourceDictionary Source="Resources/CCConfigurationTemplate.xaml" />
                <ResourceDictionary Source="Resources/TrackConfigurationTemplate.xaml" />
                <ResourceDictionary Source="Resources/ImageConfigurationTemplate.xaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</prism:PrismApplication>
